# ============================================================
# RavenOps Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# MongoDB
MONGODB_URI=mongodb://ravenops:ravenops_pass@mongodb:27017/ravenops?authSource=admin
MONGODB_DB_NAME=ravenops

# Redis
REDIS_URL=redis://:ravenops_redis@redis:6379/0

# RabbitMQ (local Service Bus replacement)
SERVICE_BUS_PROVIDER=rabbitmq
RABBITMQ_URL=amqp://ravenops:ravenops_pass@rabbitmq:5672/

# Azure Blob Storage (Azurite for local dev)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURE_BLOB_CONTAINER=ravenops-logs

# Azure OpenAI (openai-mock for local dev)
AZURE_OPENAI_ENDPOINT=http://openai-mock:8080
AZURE_OPENAI_API_KEY=mock-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=ravenops-webhook-secret-local
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Internal Service URLs (Docker network)
AUTH_SERVICE_URL=http://auth-service:8001
GITHUB_SERVICE_URL=http://github-service:8002
WORKFLOW_SERVICE_URL=http://workflow-service:8003
LOG_SERVICE_URL=http://log-service:8004
PARSER_SERVICE_URL=http://parser-service:8005
AI_SERVICE_URL=http://ai-service:8006
ANALYTICS_SERVICE_URL=http://analytics-service:8007
NOTIFICATION_SERVICE_URL=http://notification-service:8008

# Email / SMTP (MailHog for local dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ravenops.local

# Slack / Teams (optional)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
